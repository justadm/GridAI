[Unit]
Description=SkillRadar Telegram Bot (system node)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/skillradar
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /opt/skillradar/src/index.js
Restart=always
RestartSec=5
StandardOutput=append:/var/log/skillradar.log
StandardError=append:/var/log/skillradar.log

[Install]
WantedBy=multi-user.target
